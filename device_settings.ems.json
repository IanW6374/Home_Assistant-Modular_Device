    "dc": 8,
    "rst": 12,
    "refresh_ms": 1000,
    "button_a": 14,
    "button_b": 15,
    "button_a_short": "next_page",
    "button_a_long": "refresh_discovery",
    "button_b_short": "previous_page",
    "button_b_long": "toggle_loglevel"
