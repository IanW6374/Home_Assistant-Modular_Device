{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Home Assistant Modular Device firmware settings",
  "type": "object",
  "required": ["device"],
  "properties": {
    "device": {
      "type": "object",
      "required": ["name", "module_settings_file", "ca_cert_path"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "module_settings_file": {
          "type": "string",
          "minLength": 1
        },
        "ca_cert_path": {
          "type": "string",
          "minLength": 1
        },
        "loglevel": {
          "type": "string",
          "enum": ["ERROR", "INFO", "DEBUG"]
        },
        "watchdog_timeout_ms": {
          "type": "integer",
          "minimum": 0
        },
        "wifi_recovery_enabled": {
          "type": "boolean"
        },
        "wifi_recovery_timeout_s": {
          "type": "integer",
          "minimum": 60,
          "maximum": 86400
        },
        "status_led_pin": {
          "type": ["integer", "string", "null"]
        },
        "status_led_type": {
          "type": "string",
          "enum": ["auto", "digital", "neopixel"]
        },
        "ntp_servers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "ha": {
      "type": "object",
      "properties": {
        "discovery": {
          "type": "boolean"
        },
        "discovery_cleanup_legacy_identity": {
          "type": "boolean"
        },
        "discovery_cleanup_legacy": {
          "type": "boolean"
        },
        "discovery_cleanup_legacy_count": {
          "type": "integer",
          "minimum": 0
        },
        "system_diagnostics": {
          "type": "boolean"
        },
        "device_info": {
          "type": "object",
          "properties": {
            "mf": {
              "type": "string"
            },
            "mdl": {
              "type": "string"
            },
            "sw": {
              "type": "string"
            },
            "sw_version": {
              "type": "string"
            },
            "hw": {
              "type": "string"
            }
          },
          "additionalProperties": {
            "type": ["string", "number", "boolean", "null"]
          }
        }
      },
      "additionalProperties": false
    },
    "web_portal": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "https": {
          "type": "boolean"
        },
        "host": {
          "type": "string",
          "minLength": 1
        },
        "port": {
          "type": ["integer", "null"],
          "minimum": 1,
          "maximum": 65535
        },
        "cert_path": {
          "type": "string",
          "minLength": 1
        },
        "key_path": {
          "type": "string",
          "minLength": 1
        },
        "log_refresh_s": {
          "type": "integer",
          "minimum": 1
        },
        "value_refresh_s": {
          "type": "integer",
          "minimum": 0
        },
        "log_buffer_lines": {
          "type": "integer",
          "minimum": 0
        },
        "log_line_max_chars": {
          "type": "integer",
          "minimum": 1
        },
        "updates_enabled": {
          "type": "boolean"
        },
        "update_max_bytes": {
          "type": "integer",
          "minimum": 1024
        },
        "allow_protected_updates": {
          "type": "boolean"
        },
        "firmware_updates_enabled": {
          "type": "boolean"
        },
        "firmware_update_max_bytes": {
          "type": "integer",
          "minimum": 1024
        },
        "release_manifest_url": {
          "type": "string"
        },
        "release_channel": {
          "type": "string",
          "enum": ["stable", "beta", "development"]
        },
        "release_check_interval_s": {
          "type": "integer",
          "minimum": 300
        },
        "release_auto_download": {
          "type": "boolean"
        },
        "release_auto_activate": {
          "type": "boolean"
        },
        "session_timeout_s": {
          "type": "integer",
          "minimum": 300,
          "maximum": 86400
        }
      },
      "additionalProperties": false
    },
    "local_display": {
      "type": "object",
      "required": ["enabled"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "type": {
          "type": "string",
          "enum": ["SH1107-SPI"]
        },
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "spi": {
          "type": "integer",
          "minimum": 0
        },
        "sck": {
          "type": "integer",
          "minimum": 0
        },
        "mosi": {
          "type": "integer",
          "minimum": 0
        },
        "cs": {
          "type": "integer",
          "minimum": 0
        },
        "dc": {
          "type": "integer",
          "minimum": 0
        },
        "rst": {
          "type": "integer",
          "minimum": 0
        },
        "baudrate": {
          "type": "integer",
          "minimum": 1
        },
        "rotate": {
          "type": "integer",
          "enum": [0, 180]
        },
        "refresh_ms": {
          "type": "integer",
          "minimum": 250
        },
        "button_poll_ms": {
          "type": "integer",
          "minimum": 10
        },
        "long_press_ms": {
          "type": "integer",
          "minimum": 100
        },
        "button_a": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "button_b": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "button_active_low": {
          "type": "boolean"
        },
        "button_a_short": {
          "type": "string"
        },
        "button_a_long": {
          "type": "string"
        },
        "button_b_short": {
          "type": "string"
        },
        "button_b_long": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
